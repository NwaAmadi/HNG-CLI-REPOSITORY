# Backend base URL used by the CLI for every request.
INSIGHTA_API_BASE_URL=https://your-backend.example.com

# Path on your backend that starts the GitHub OAuth PKCE flow for the CLI.
INSIGHTA_AUTH_START_PATH=/auth/github

# Path used by the CLI to exchange the OAuth code + PKCE verifier for tokens.
INSIGHTA_AUTH_EXCHANGE_PATH=/auth/cli/exchange

# Auth endpoints used for automatic refresh and logout.
INSIGHTA_AUTH_REFRESH_PATH=/auth/refresh
INSIGHTA_AUTH_LOGOUT_PATH=/auth/logout

# User and profiles API paths.
INSIGHTA_ME_PATH=/api/users/me
INSIGHTA_PROFILES_PATH=/api/profiles
INSIGHTA_PROFILES_SEARCH_PATH=/api/profiles/search
INSIGHTA_PROFILES_EXPORT_PATH=/api/profiles/export

# The required API version header value for profile endpoints.
INSIGHTA_API_VERSION=1

# Local callback server settings for `insighta login`.
INSIGHTA_CALLBACK_HOST=127.0.0.1
INSIGHTA_CALLBACK_PORT=8787

# Local location for stored CLI credentials.
INSIGHTA_CREDENTIALS_FILE=~/.insighta/credentials.json
